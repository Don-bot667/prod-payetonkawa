{
  "info": {
    "name": "PayeTonKawa",
    "_postman_id": "payetonkawa-collection-v1",
    "description": "Collection complète pour l'API PayeTonKawa — microservices café.\nAuthentification : header X-API-Key requis sur toutes les routes métier.\n\nEnvironnement recommandé : PayeTonKawa_local",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "apikey",
    "apikey": [
      { "key": "key",   "value": "X-API-Key",    "type": "string" },
      { "key": "value", "value": "{{api_key}}",   "type": "string" },
      { "key": "in",    "value": "header",         "type": "string" }
    ]
  },
  "item": [
    {
      "name": "Health",
      "description": "Endpoints de monitoring — pas d'authentification requise.",
      "item": [
        {
          "name": "Health — API Clients",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url_clients}}/health",
              "host": ["{{base_url_clients}}"],
              "path": ["health"]
            },
            "description": "Vérifie l'état de l'API Clients et de sa base de données PostgreSQL."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Service healthy', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.status).to.eql('healthy');",
                  "  pm.expect(json.service).to.eql('api-clients');",
                  "  pm.expect(json.database).to.eql('connected');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Health — API Produits",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
