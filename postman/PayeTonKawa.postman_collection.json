    {
      "name": "Commandes",
      "description": "CRUD complet sur les commandes clients. Toutes les routes nécessitent X-API-Key.",
      "item": [
        {
          "name": "Créer une commande",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"client_id\": 1,\n  \"lignes\": [\n    {\n      \"produit_id\": 1,\n      \"quantite\": 2,\n      \"prix_unitaire\": 12.50\n    },\n    {\n      \"produit_id\": 2,\n      \"quantite\": 1,\n      \"prix_unitaire\": 8.00\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url_commandes}}/orders/",
              "host": ["{{base_url_commandes}}"],
              "path": ["orders", ""]
            },
            "description": "Crée une nouvelle commande avec ses lignes. Le total est calculé automatiquement (somme de quantite * prix_unitaire). Publie un événement commande.created sur RabbitMQ."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Commande créée', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('id');",
                  "  pm.expect(json.statut).to.eql('en_attente');",
                  "  pm.expect(json.total).to.eql(33.0);",
                  "  pm.expect(json.lignes).to.be.an('array').with.lengthOf(2);",
                  "  pm.environment.set('commande_id', json.id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Lister les commandes",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url_commandes}}/orders/?skip=0&limit=50",
