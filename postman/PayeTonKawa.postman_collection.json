    {
      "name": "Authentification (tests négatifs)",
      "description": "Tests des cas d'erreur d'authentification — permet de vérifier que les protections API Key fonctionnent.",
      "item": [
        {
          "name": "Sans API Key → 401",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url_clients}}/customers/",
              "host": ["{{base_url_clients}}"],
              "path": ["customers", ""]
            },
            "description": "Requête sans header X-API-Key. Doit retourner 401 Unauthorized."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 401 — clé absente', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        },
        {
