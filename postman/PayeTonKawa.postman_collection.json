                  "  const json = pm.response.json();",
                  "  pm.expect(json.status).to.eql('healthy');",
                  "  pm.expect(json.service).to.eql('api-produits');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Health — API Commandes",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url_commandes}}/health",
              "host": ["{{base_url_commandes}}"],
              "path": ["health"]
            },
            "description": "Vérifie l'état de l'API Commandes et de sa base de données PostgreSQL."
          },
