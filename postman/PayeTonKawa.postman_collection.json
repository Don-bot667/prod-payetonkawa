    {
      "name": "Clients",
      "description": "CRUD complet sur les clients. Toutes les routes nécessitent X-API-Key.",
      "item": [
        {
          "name": "Créer un client",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nom\": \"Dupont\",\n  \"prenom\": \"Jean\",\n  \"email\": \"jean.dupont@example.com\",\n  \"mot_de_passe\": \"monMdp123\",\n  \"telephone\": \"0612345678\",\n  \"adresse\": \"12 rue de la Paix, Paris 75001\"\n}"
            },
            "url": {
              "raw": "{{base_url_clients}}/customers/",
              "host": ["{{base_url_clients}}"],
              "path": ["customers", ""]
            },
            "description": "Crée un nouveau client. Le mot de passe est haché avec bcrypt avant stockage."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Client créé avec ID', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('id');",
                  "  pm.expect(json.email).to.eql('jean.dupont@example.com');",
                  "  pm.expect(json).to.not.have.property('mot_de_passe');",
                  "  pm.environment.set('client_id', json.id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Lister les clients",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url_clients}}/customers/?skip=0&limit=20",
              "host": ["{{base_url_clients}}"],
              "path": ["customers", ""],
              "query": [
                { "key": "skip",  "value": "0" },
                { "key": "limit", "value": "20" }
              ]
            },
            "description": "Retourne la liste paginée des clients. Paramètres : skip (défaut 0) et limit (défaut 100)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Réponse est un tableau', () => {",
                  "  pm.expect(pm.response.json()).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Obtenir un client par ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url_clients}}/customers/{{client_id}}",
              "host": ["{{base_url_clients}}"],
              "path": ["customers", "{{client_id}}"]
            },
            "description": "Retourne un client par son identifiant. 404 si introuvable."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('ID correspond', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(String(json.id)).to.eql(pm.environment.get('client_id'));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Connexion client",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jean.dupont@example.com\",\n  \"mot_de_passe\": \"monMdp123\"\n}"
            },
            "url": {
              "raw": "{{base_url_clients}}/customers/login",
              "host": ["{{base_url_clients}}"],
              "path": ["customers", "login"]
            },
            "description": "Authentifie un client par email + mot de passe. Retourne 401 si les credentials sont incorrects."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Connexion réussie', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('id');",
                  "  pm.expect(json.email).to.eql('jean.dupont@example.com');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Modifier un client",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"adresse\": \"99 avenue des Champs, Lyon 69001\",\n  \"telephone\": \"0698765432\"\n}"
            },
            "url": {
              "raw": "{{base_url_clients}}/customers/{{client_id}}",
              "host": ["{{base_url_clients}}"],
              "path": ["customers", "{{client_id}}"]
            },
            "description": "Modifie partiellement un client. Seuls les champs envoyés sont mis à jour."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Adresse mise à jour', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.adresse).to.eql('99 avenue des Champs, Lyon 69001');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Supprimer un client",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url_clients}}/customers/{{client_id}}",
              "host": ["{{base_url_clients}}"],
              "path": ["customers", "{{client_id}}"]
            },
            "description": "Supprime un client. Publie un événement client.deleted sur RabbitMQ. Retourne 204."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 204', () => pm.response.to.have.status(204));"
                ]
              }
            }
          ]
        }
      ]
    },
